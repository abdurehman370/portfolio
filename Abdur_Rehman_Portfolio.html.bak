  <div id="portfolio-lightbox" class="portfolio-lightbox" aria-hidden="true">
    <div class="portfolio-lightbox__backdrop" role="presentation"></div>
    <div class="portfolio-lightbox__dialog" role="dialog" aria-modal="true" aria-label="Screenshot gallery">
      <button type="button" class="portfolio-lightbox__close" aria-label="Close gallery">&times;</button>
      <button type="button" class="portfolio-lightbox__nav portfolio-lightbox__nav--prev is-hidden" aria-label="Previous screenshot">&#8249;</button>
      <button type="button" class="portfolio-lightbox__nav portfolio-lightbox__nav--next is-hidden" aria-label="Next screenshot">&#8250;</button>
      <figure class="portfolio-lightbox__figure">
        <img class="portfolio-lightbox__img" src="" alt="" decoding="async" />
        <figcaption class="portfolio-lightbox__caption"></figcaption>
      </figure>
      <div class="portfolio-lightbox__counter"></div>
    </div>
  </div>

  <script>
    (function () {
      var lb = document.getElementById("portfolio-lightbox");
      if (!lb) return;

      var imgEl = lb.querySelector(".portfolio-lightbox__img");
      var capEl = lb.querySelector(".portfolio-lightbox__caption");
      var counterEl = lb.querySelector(".portfolio-lightbox__counter");
      var btnClose = lb.querySelector(".portfolio-lightbox__close");
      var btnPrev = lb.querySelector(".portfolio-lightbox__nav--prev");
      var btnNext = lb.querySelector(".portfolio-lightbox__nav--next");
      var backdrop = lb.querySelector(".portfolio-lightbox__backdrop");

      var slides = [];
      var index = 0;
      var lastFocus = null;

      function updateNavVisibility() {
        var multi = slides.length > 1;
        btnPrev.classList.toggle("is-hidden", !multi);
        btnNext.classList.toggle("is-hidden", !multi);
      }

      function render() {
        if (!slides.length) return;
        var s = slides[index];
        imgEl.src = s.src;
        imgEl.alt = s.alt;
        capEl.textContent = s.caption;
        counterEl.textContent = slides.length > 1 ? index + 1 + " / " + slides.length : "";
        updateNavVisibility();
      }

      function open(slidesData, startIndex) {
        slides = slidesData;
        index = startIndex;
        lastFocus = document.activeElement;
        lb.setAttribute("aria-hidden", "false");
        lb.classList.add("is-open");
        document.documentElement.style.overflow = "hidden";
        render();
        btnClose.focus();
      }

      function close() {
        lb.classList.remove("is-open");
        lb.setAttribute("aria-hidden", "true");
        document.documentElement.style.overflow = "";
        slides = [];
        imgEl.removeAttribute("src");
        imgEl.alt = "";
        capEl.textContent = "";
        counterEl.textContent = "";
        if (lastFocus && typeof lastFocus.focus === "function") lastFocus.focus();
      }

      function prev() {
        if (slides.length < 2) return;
        index = (index - 1 + slides.length) % slides.length;
        render();
      }

      function next() {
        if (slides.length < 2) return;
        index = (index + 1) % slides.length;
        render();
      }

      document.querySelectorAll(".project-gallery").forEach(function (gallery) {
        gallery.querySelectorAll("figure").forEach(function (fig) {
          fig.setAttribute("tabindex", "0");
          fig.setAttribute("role", "button");
          var cap = fig.querySelector("figcaption");
          var hint = cap ? cap.textContent.trim() : "screenshot";
          fig.setAttribute("aria-label", "Open gallery: " + hint);
        });

        gallery.addEventListener("click", function (e) {
          var fig = e.target.closest("figure");
          if (!fig || !gallery.contains(fig)) return;
          e.preventDefault();
          var figures = Array.prototype.slice.call(gallery.querySelectorAll("figure"));
          var slidesData = figures.map(function (f) {
            var im = f.querySelector("img");
            var c = f.querySelector("figcaption");
            return {
              src: im.getAttribute("src"),
              alt: im.getAttribute("alt") || "",
              caption: c ? c.textContent.trim() : ""
            };
          });
          open(slidesData, figures.indexOf(fig));
        });

        gallery.addEventListener("keydown", function (e) {
          if (e.key !== "Enter" && e.key !== " ") return;
          var fig = e.target.closest("figure");
          if (!fig || !gallery.contains(fig)) return;
          e.preventDefault();
          fig.click();
        });
      });

      btnClose.addEventListener("click", function (e) {
        e.stopPropagation();
        close();
      });
      backdrop.addEventListener("click", close);
      btnPrev.addEventListener("click", function (e) {
        e.stopPropagation();
        prev();
      });
      btnNext.addEventListener("click", function (e) {
        e.stopPropagation();
        next();
      });

      lb.addEventListener("click", function (e) {
        if (e.target === lb) close();
      });

      document.addEventListener("keydown", function (e) {
        if (!lb.classList.contains("is-open")) return;
        if (e.key === "Escape") {
          e.preventDefault();
          close();
        } else if (e.key === "ArrowLeft") {
          e.preventDefault();
          prev();
        } else if (e.key === "ArrowRight") {
          e.preventDefault();
          next();
        }
      });

      if ("IntersectionObserver" in window) {
        var revealSet = document.querySelectorAll("section, .hero .hero-card, .hero .stats .stat-box");
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (en) {
              if (en.isIntersecting) {
                en.target.classList.add("reveal-visible");
                io.unobserve(en.target);
              }
            });
          },
          { threshold: 0.06, rootMargin: "0px 0px -32px 0px" }
        );
        revealSet.forEach(function (el) {
          el.classList.add("reveal-on-scroll");
          io.observe(el);
        });
      }
    })();
  </script>
</body>
</html>
